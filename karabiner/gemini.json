{
  "title": "settings for Gemini",
  "rules": [
    {
      "description": "Gemini appで ctrl+j → shift+return",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "j",
            "modifiers": {
              "mandatory": ["control"],
              "optional": ["any"]
            }
          },
          "to": [
            {
              "key_code": "return_or_enter",
              "modifiers": ["shift"]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.google\\.GeminiMacOS$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
